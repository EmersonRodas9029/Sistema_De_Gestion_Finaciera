# Copia este archivo a .env y completa valores reales. .env NUNCA se commitea (ver .gitignore).
# docker-compose y la app (via variables de entorno del sistema operativo/IDE) leen de aquí.

# --- Base de datos ---
DB_HOST=localhost
DB_PORT=3307
DB_NAME=sistema_gastos_clientes
DB_USERNAME=root
DB_PASSWORD=cambia-esto-por-un-password-fuerte

# --- JWT ---
# Generar con: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRATION=86400000

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
